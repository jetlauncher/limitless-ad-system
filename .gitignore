# macOS
.DS_Store
.AppleDouble
.LSOverride

# Editor directories
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# Node (if you add a local server or tooling)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment files — never commit real API keys
.env
.env.local
.env.*.local
# .env.example is safe to commit (no real keys)

# Brand materials — kept local, not committed
brand/brand-book/*
brand/reference-images/*
brand/generated-briefs/*
!brand/brand-book/.gitkeep
!brand/reference-images/.gitkeep
!brand/generated-briefs/.gitkeep

# Vercel
.vercel

# Build output (if added later)
dist/
build/
out/

# Temp files
*.tmp
*.bak
*.swp
*~

# Campaign folders — kept local, not committed
# The campaigns/ folder itself is tracked (via .gitkeep) so the structure is visible in git.
campaigns/*
!campaigns/.gitkeep
