# -------------------------------------------------------
# Limitless Ad System — Environment Variables
# -------------------------------------------------------
# Copy this file to .env and fill in your values.
# Never commit .env to git — it is already in .gitignore.
# -------------------------------------------------------

# --- Option A: OpenAI / ChatGPT ---
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# --- Option B: OpenRouter (access many models via one key) ---
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# --- Image generation settings ---
# Provider: "openai" | "openrouter" | "replicate" | "fal"
IMAGE_PROVIDER=openai

# Model to use for image generation
# OpenAI options:    dall-e-3 | dall-e-2
# OpenRouter options: check https://openrouter.ai/models for image-capable models
IMAGE_MODEL=dall-e-3
