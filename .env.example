# -------------------------------------------------------
# Limitless Ad System — Environment Variables
# -------------------------------------------------------
# Copy this file to .env and fill in your values.
# Never commit .env to git — it is already in .gitignore.
# -------------------------------------------------------

# --- Option A: OpenAI / ChatGPT ---
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# --- Option B: OpenRouter (access many models via one key) ---
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# --- Text generation settings ---
# Used by scripts/generate_campaign_assets.py for concept + copy generation.
# Provider: "openai" | "openrouter"
TEXT_PROVIDER=openai

# Text model for concept and copy generation.
# OpenAI options:    gpt-4.1-mini | gpt-4.1 | gpt-4o-mini
# OpenRouter options: openai/gpt-4.1-mini | anthropic/claude-3.7-sonnet | google/gemini-2.5-pro-preview
TEXT_MODEL=gpt-4.1-mini

# --- Image generation settings ---
# These are for your image workflow outside the generator script.
# Provider: "openai" | "openrouter" | "replicate" | "fal"
IMAGE_PROVIDER=openai

# Model to use for image generation
# OpenAI options: dall-e-3 | gpt-image-1
# OpenRouter options: use only models/provider paths you have personally tested for image workflows
IMAGE_MODEL=gpt-image-1
